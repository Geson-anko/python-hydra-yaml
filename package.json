{
  "name": "hydra-yaml",
  "displayName": "hydra-yaml",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:yaml"
  ],
  "extensionDependencies": [
    "ms-python.python"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "yaml"
      }
    ],
    "commands": [
      {
        "command": "hydra-yaml.selectPythonInterpreter",
        "title": "Hydra: Select Python Interpreter"
      },
      {
        "command": "hydra-yaml.selectRootConfigFile",
        "title": "Hydra: Select Root Config File"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "yarn run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "yarn run compile && yarn run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "fmt": "yarn dprint fmt"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.96.0",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "dprint": "^0.48.0",
    "eslint": "^9.16.0",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@vscode/python-extension": "^1.0.5",
    "yaml": "^2.7.0"
  }
}
