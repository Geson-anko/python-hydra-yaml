{
  "name": "python-hydra-yaml",
  "displayName": "python-hydra-yaml",
  "publisher": "GesonAnko",
  "license": "MIT",
  "icon": "./images/logo.png",
  "description": "Helping to write complex hydra yaml configs.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Linters",
    "Data Science",
    "Machine Learning",
    "Programming Languages"
  ],
  "keywords": ["hydra", "python", "yaml", "omegaconf", "config"],
  "activationEvents": [
    "onLanguage:yaml"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Geson-anko/python-hydra-yaml.git"
  },
  "homepage": "https://github.com/Geson-anko/python-hydra-yaml",
  "extensionDependencies": [
    "ms-python.python"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "yaml"
      }
    ],
    "commands": []
  },
  "scripts": {
    "vscode:prepublish": "yarn run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "yarn run compile && yarn run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "fmt": "yarn dprint fmt"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.96.0",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "dprint": "^0.48.0",
    "eslint": "^9.16.0",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@vscode/python-extension": "^1.0.5",
    "yaml": "^2.7.0"
  }
}
